---
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@/utils/slugify";
import { getPath } from "@/utils/getPath";
import Datetime from "./Datetime.astro";

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"blog">;

const { variant: Heading = "h2", id, data, filePath } = Astro.props;
// 1. 关键：解构出同步脚本生成的 heroImage
const { title, description, heroImage, ...props } = data;
---

<li class="group relative overflow-hidden rounded-[2rem] border border-white/20 bg-white/5 transition-all duration-500 hover:scale-[1.02] hover:shadow-2xl h-full min-h-[350px]">
  
  <a href={getPath(id, filePath)} class="block h-full w-full">
    
    {heroImage && (
      <div class="absolute inset-0 z-0">
        <img 
          src={heroImage} 
          alt={title} 
          class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110" 
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent"></div>
      </div>
    )}

    <div class="relative z-10 flex h-full flex-col justify-end p-6 min-h-[280px]">
      <div class="rounded-2xl border border-white/10 bg-white/5 p-4 backdrop-blur-md">
        <Heading
          class="text-xl font-bold text-white line-clamp-2 leading-tight"
          style={{ viewTransitionName: slugifyStr(title.replaceAll(".", "-")) }}
        >
          {title}
        </Heading>
        
        <div class="mt-2 opacity-80">
          <Datetime {...props} />
        </div>
        
        <p class="mt-3 line-clamp-2 text-sm text-white/70">
          {description}
        </p>
        
        <div class="mt-4 h-[1px] w-8 bg-white/20 transition-all group-hover:w-full group-hover:bg-blue-400"></div>
      </div>
    </div>
  </a>
</li>

